# =========================================================================
# Event-Scraper-Agent 環境變數設定範本
# 使用步驟:
# 1. 複製此檔案並重新命名為 `.env`
# 2. 填入您的 API 金鑰與電子郵件帳密設定
# 3. 確保 `.env` 已加入 `.gitignore` 以防機密資訊外洩
# =========================================================================

# 運行環境: development (開發，網頁爬取時會開瀏覽器視窗) 或 production (正式，背景爬取)
ENVIRONMENT=development

# 是否開啟本地網頁爬取快取 (True / False): 開啟後第二次爬取同 URL 會直接讀取本地 cache 檔案
USE_CACHE=True
CACHE_DIR=cache
SENT_HISTORY_FILE=sent_events.json

# Gemini API 金鑰 (用於活動結構化萃取)
# 申請網址: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 電子郵件通知設定 (以 Gmail 為例)
# SENDER_PASSWORD 需要是 Gmail 的「應用程式密碼」，而非一般登入密碼
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here
