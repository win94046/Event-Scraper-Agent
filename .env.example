# =========================================================================
# Event-Scraper-Agent 環境變數設定範本
# 使用步驟:
# 1. 複製此檔案並重新命名為 `.env`
# 2. 填入您的 API 金鑰與電子郵件帳密設定
# 3. 確保 `.env` 已加入 `.gitignore` 以防機密資訊外洩
# =========================================================================

# 運行環境: development (開發，網頁爬取時會開瀏覽器視窗) 或 production (正式，背景爬取)
ENVIRONMENT=development

# 是否開啟本地網頁爬取快取 (True / False): 開啟後第二次爬取同 URL 會直接讀取本地 cache 檔案
USE_CACHE=True
CACHE_DIR=cache
SENT_HISTORY_FILE=sent_events.json

# Gemini API 金鑰 (用於活動結構化萃取)
# 申請網址: https://aistudio.google.com/
#
# 安全建議 (PowerShell 注入範例):
#   $env:GEMINI_API_KEY="您的真實金鑰"
#   venv\Scripts\python main.py
GEMINI_API_KEY=your_gemini_api_key_here

# Google Custom Search JSON API 設定 (Facebook 爬蟲雙路線專用)
# 1. GOOGLE_CSE_API_KEY: Google Cloud Console 啟動 "Custom Search API" 後產生的金鑰
# 2. GOOGLE_CSE_CX: Programmable Search Engine 建立搜尋引擎後產生的搜尋引擎 ID
# 3. FACEBOOK_SCRAPER_USE_API: 是否預設使用 API 搜尋 (True / False)
#
# 安全建議 (PowerShell 注入範例):
#   $env:GOOGLE_CSE_API_KEY="您的真實 API Key"
#   $env:GOOGLE_CSE_CX="您的真實搜尋引擎 CX ID"
#   $env:FACEBOOK_SCRAPER_USE_API="True"
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_CX=your_google_cse_cx_here
FACEBOOK_SCRAPER_USE_API=True

# 電子郵件通知設定 (以 Gmail 為例)
# SENDER_PASSWORD 需要是 Gmail 的「應用程式密碼」，而非一般登入密碼
# 
# 安全建議 (PowerShell 注入範例):
#   $env:SENDER_PASSWORD="您的應用程式密碼"
#   venv\Scripts\python main.py
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here

